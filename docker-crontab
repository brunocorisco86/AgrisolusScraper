# Crontab do monitoramento Agrisolus no Docker
# Importante: O cron do Debian exige que as linhas terminem com quebra de linha e que haja uma linha em branco no fim.

# A cada 1 hora: roda o scraper principal
0 * * * * cd /app && /usr/local/bin/python src/main.py >> /app/cron.log 2>&1

# Às 06:00, 11:00, 13:00 e 16:00: envia o resumo periódico de silos offline
0 6,11,13,16 * * * cd /app && /usr/local/bin/python scripts/run_periodic_summary.py >> /app/cron.log 2>&1

# Às 18:00: envia o relatório diário de SLA & Consumo
0 18 * * * cd /app && /usr/local/bin/python scripts/run_sla_report.py >> /app/cron.log 2>&1

# Linha em branco obrigatória abaixo
